{
  "name": "InventoryMobile",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready React Native CLI inventory management SaaS mobile application.",
  "scripts": {
    "firebase:android": "node scripts/generate-google-services.js",
    "preandroid": "npm run firebase:android",
